# Defaults for local development and CI.
#
# Production secrets must be configured as global server/environment variables
# or placed in ../private-config/ctc*.env on the server. Never commit real
# passwords, tokens, client secrets or database credentials here.
#
# Existing server variables always win over this file.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-only-for-local-development
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

APP_PLATFORM_NAME="CMS to Commerce Hub"
CMS_DEFAULT_LANGUAGE=de

# Optional explicit path to a private env-style secrets file.
# Empty means CTC auto-checks ../private-config/ctc.env and channel-specific files.
APP_EXTERNAL_SECRETS_FILE=

# Admin/API protection: set real values via server env or private-config.
APP_ADMIN_PASSWORD_HASH='$2y$12$nF7.8HGKKebSf8G/gMqZTOCvseIJcdtG0V9zvRnjFZSRyD.k/mNim'
APP_IMPORT_API_TOKEN=

# Shopware Admin API.
SHOPWARE_BASE_URL=
SHOPWARE_ADMIN_BASE_URL=
SHOPWARE_ADMIN_USERNAME=
SHOPWARE_ADMIN_PASSWORD=
SHOPWARE_SYNC_CATEGORY="Amazon Imports"

# Amazon SP-API. Live publish stays disabled until explicitly enabled server-side.
AMAZON_REGION=eu
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=
AMAZON_APP_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SP_API_BASE_URL=
AMAZON_LWA_BASE_URL=
AMAZON_ENABLE_LIVE_PUBLISH=0

# JTL. Live write-back stays disabled until explicitly enabled server-side.
JTL_API_BASE_URL=
JTL_AUTH_BASE_URL=
JTL_TENANT_ID=
JTL_CLIENT_ID=
JTL_CLIENT_SECRET=
JTL_ENABLE_LIVE_WRITEBACK=0
JTL_RUNAS=
JTL_COMPANY_ID=

# plentymarkets. Live write-back stays disabled until explicitly enabled server-side.
PLENTY_BASE_URL=
PLENTY_USERNAME=
PLENTY_PASSWORD=
PLENTY_DEFAULT_LANG=de
PLENTY_ENABLE_LIVE_WRITEBACK=0
