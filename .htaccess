Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(?:src|config|templates|vendor|var|migrations|tests|translations|product-listing-builder)(?:/|$) - [F,L]
    RewriteRule ^(?:\.env|composer\.(?:json|lock)|symfony\.lock|phpunit\.dist\.xml|README\.md|compose(?:\.override)?\.yaml)$ - [F,L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond public/$1 -f [OR]
    RewriteCond public/$1 -d
    RewriteRule ^(.*)$ public/$1 [L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>
