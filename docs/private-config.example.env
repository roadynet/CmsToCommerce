# Beispiel für ../private-config/ctc.env
# Diese Datei ist eine Vorlage. Echte Werte niemals committen.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-with-long-random-secret
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null

APP_PLATFORM_NAME="CMS to Commerce Hub"
CMS_DEFAULT_LANGUAGE=de
APP_ADMIN_PASSWORD_HASH="$2y$12$replace-with-real-bcrypt-hash"
APP_IMPORT_API_TOKEN=replace-with-long-random-token

SHOPWARE_BASE_URL=https://sw.example.test
SHOPWARE_ADMIN_BASE_URL=https://sw.example.test
SHOPWARE_ADMIN_USERNAME=admin@example.invalid
SHOPWARE_ADMIN_PASSWORD=replace-with-shopware-admin-password
SHOPWARE_SYNC_CATEGORY=Amazon Imports

AMAZON_REGION=eu
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=
AMAZON_APP_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SP_API_BASE_URL=
AMAZON_LWA_BASE_URL=
AMAZON_ENABLE_LIVE_PUBLISH=0

JTL_API_BASE_URL=
JTL_AUTH_BASE_URL=
JTL_TENANT_ID=
JTL_CLIENT_ID=
JTL_CLIENT_SECRET=
JTL_ENABLE_LIVE_WRITEBACK=0
JTL_RUNAS=
JTL_COMPANY_ID=

PLENTY_BASE_URL=
PLENTY_USERNAME=
PLENTY_PASSWORD=
PLENTY_DEFAULT_LANG=de
PLENTY_ENABLE_LIVE_WRITEBACK=0

SAP_R3_GATEWAY_URL=
SAP_R3_WRITEBACK_PATH=/ctc/material/writeback
SAP_R3_CLIENT=
SAP_R3_USERNAME=
SAP_R3_PASSWORD=
SAP_R3_SYSTEM_ID=
SAP_R3_LANGUAGE=DE
SAP_R3_ENABLE_LIVE_WRITEBACK=0

PIMCORE_BASE_URL=
PIMCORE_API_TOKEN=
PIMCORE_WRITEBACK_PATH=/ctc/object/writeback
PIMCORE_DEFAULT_LANGUAGE=de
PIMCORE_ENABLE_LIVE_WRITEBACK=0
