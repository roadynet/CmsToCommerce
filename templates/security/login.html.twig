{% extends 'base.html.twig' %}

{% block title %}Anmeldung · CMS to Commerce Hub{% endblock %}

{% block body %}
    <section class="login-shell">
        <div class="panel">
            <p class="eyebrow">Admin-Zugang</p>
            <h1>Anmeldung</h1>
            <p>Melde dich an, um Produkte zu importieren, Produktseiten zu prüfen und Exporte auszulösen.</p>

            {% if error %}
                <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form class="form-grid" method="post">
                <div class="form-group form-group-full">
                    <label for="username">Benutzer</label>
                    <input id="username" type="text" name="_username" value="{{ last_username }}" autocomplete="username" required autofocus>
                </div>

                <div class="form-group form-group-full">
                    <label for="password">Passwort</label>
                    <input id="password" type="password" name="_password" autocomplete="current-password" required>
                </div>
                <div class="button-group">
                    <button class="button button-primary" type="submit">Anmelden</button>
                </div>
            </form>
        </div>
    </section>
{% endblock %}
