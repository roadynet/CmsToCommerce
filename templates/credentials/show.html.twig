{% extends 'base.html.twig' %}

{% block title %}Zugangsdaten · CMS to Commerce Hub{% endblock %}

{% block body %}
    <section class="page-header">
        <div>
            <p class="eyebrow">Systemzugänge</p>
            <h1>Zugangsdaten</h1>
            <p>Hier pflegst du die API-Zugänge je Channel/System. Geheime Werte werden nicht im Klartext angezeigt und bleiben erhalten, wenn du das Feld leer lässt.</p>
        </div>
        <div class="button-group">
            <a class="button" href="{{ path('app_dashboard') }}">Zur Übersicht</a>
            <a class="button" href="{{ path('app_form_hub_index') }}">Formulare</a>
            <a class="button button-primary" href="{{ path('app_product_index') }}">Produkte</a>
        </div>
    </section>

    <section class="grid-2">
        <div class="panel">
            <h2>Channels</h2>
            <p class="muted-copy">Wähle links das System aus und speichere rechts dessen private Konfiguration.</p>

            <div class="stack">
                {% for slug, channel in channels %}
                    <a class="mini-card link-card {{ slug == active_slug ? 'active-card' : '' }}" href="{{ path('app_credentials_show', {channel: slug}) }}">
                        <div class="row-between">
                            <h3>{{ channel.label }}</h3>
                            <span class="badge {{ channel.ready ? 'badge-success' : 'badge-warning' }}">
                                {{ channel.ready ? 'bereit' : channel.required_missing_count ~ ' offen' }}
                            </span>
                        </div>
                        <p>{{ channel.description }}</p>
                        <p class="field-meta">{{ channel.configured_count }}/{{ channel.total_count }} Felder gesetzt · {{ channel.file }}</p>
                    </a>
                {% endfor %}
            </div>
        </div>

        <form class="panel form-grid" method="post" autocomplete="off">
            <input type="hidden" name="_token" value="{{ csrf_token('credentials_' ~ active_slug) }}">

            <div class="form-group form-group-full">
                <p class="eyebrow">{{ active_channel.badge }}</p>
                <div class="row-between">
                    <h2>{{ active_channel.label }}</h2>
                    <span class="badge {{ active_channel.ready ? 'badge-success' : 'badge-warning' }}">
                        {{ active_channel.ready ? 'vollständig' : 'Pflichtdaten offen' }}
                    </span>
                </div>
                <p>{{ active_channel.description }}</p>
                <p class="field-meta">Private Datei: <code>{{ active_channel.file_path }}</code></p>
                <p class="field-meta">{{ active_channel.safety }}</p>

                {% if not active_channel.is_writable %}
                    <div class="flash flash-warning">
                        Die private Konfigurationsablage ist aktuell nicht beschreibbar. Bitte Serverrechte für den Ordner prüfen.
                    </div>
                {% endif %}
            </div>

            {% for field in active_channel.fields %}
                <div class="form-group {{ field.type == 'checkbox' ? 'form-group-full' : '' }}">
                    {% if field.type == 'checkbox' %}
                        <label class="checkbox-row">
                            <input name="credentials[{{ field.env }}]" type="checkbox" value="1" {% if field.checked %}checked{% endif %}>
                            <span>
                                {{ field.label }}
                                <small>{{ field.env }}</small>
                            </span>
                        </label>
                    {% else %}
                        <label for="{{ field.env }}">
                            {{ field.label }}
                            {% if field.required|default(false) %}<span class="required-marker">*</span>{% endif %}
                        </label>

                        {% if field.type == 'select' %}
                            <select id="{{ field.env }}" name="credentials[{{ field.env }}]">
                                {% for option in field.options|default([]) %}
                                    <option value="{{ option }}" {% if field.value == option %}selected{% endif %}>{{ option }}</option>
                                {% endfor %}
                            </select>
                        {% else %}
                            {% set placeholder = field.placeholder|default('') %}
                            {% if placeholder == '' and field.sensitive|default(false) and field.has_value %}
                                {% set placeholder = field.masked_value %}
                            {% endif %}
                            <input
                                id="{{ field.env }}"
                                name="credentials[{{ field.env }}]"
                                type="{{ field.sensitive|default(false) ? 'password' : field.type }}"
                                value="{{ field.value }}"
                                placeholder="{{ placeholder }}"
                                {% if field.sensitive|default(false) %}autocomplete="new-password"{% endif %}
                            >
                        {% endif %}

                        <div class="field-meta">
                            <code>{{ field.env }}</code>
                            {% if field.sensitive|default(false) and field.has_value %}
                                · gespeichert als {{ field.masked_value }}
                            {% elseif field.required|default(false) and not field.has_value %}
                                · fehlt noch
                            {% endif %}
                            {% if field.help|default('') %}
                                · {{ field.help }}
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}

            <div class="form-group form-group-full">
                {% if active_channel.required_missing is not empty %}
                    <div class="flash flash-warning">
                        Noch offen: {{ active_channel.required_missing|join(', ') }}
                    </div>
                {% endif %}

                <div class="button-group">
                    <button class="button button-primary" type="submit">Zugangsdaten speichern</button>
                    <a class="button" href="{{ path('app_credentials_show', {channel: active_slug}) }}">Verwerfen</a>
                </div>
            </div>
        </form>
    </section>
{% endblock %}
