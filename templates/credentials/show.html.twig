{% extends 'base.html.twig' %}

{% block title %}Zugangsdaten · CMS to Commerce Hub{% endblock %}

{% block body %}
    {% set completion = active_channel.total_count > 0 ? ((active_channel.configured_count / active_channel.total_count) * 100)|round : 0 %}

    <div class="credential-page" data-credential-page>
        <section class="credential-hero">
            <div>
                <p class="eyebrow">Systemzugänge</p>
                <h1>Zugangsdaten</h1>
                <p>
                    API-Zugänge je Channel pflegen, ohne Token im Klartext zu zeigen.
                    Leere Secret-Felder behalten den gespeicherten Wert.
                </p>
            </div>

            <div class="credential-metrics" aria-label="Zugangsdaten Status">
                <article>
                    <strong>{{ credential_summary.ready }}</strong>
                    <span>bereit</span>
                </article>
                <article>
                    <strong>{{ credential_summary.open_fields }}</strong>
                    <span>Pflichtfelder offen</span>
                </article>
                <article>
                    <strong>{{ credential_summary.total }}</strong>
                    <span>Systeme</span>
                </article>
            </div>
        </section>

        <section class="credential-layout">
            <aside class="credential-sidebar panel">
                <div class="credential-sidebar-head">
                    <div>
                        <p class="eyebrow">Channels</p>
                        <h2>Verbindungen</h2>
                    </div>
                    <span class="badge">{{ credential_summary.total }}</span>
                </div>

                <label class="credential-search">
                    <span>Suchen</span>
                    <input type="search" placeholder="Shopware, Amazon, PIM …" data-credential-search>
                </label>

                <div class="credential-list" data-credential-list>
                    {% for slug, channel in channels %}
                        {% if loop.index <= 6 %}
                            <a
                                class="credential-card {{ slug == active_slug ? 'active-card' : '' }}"
                                href="{{ path('app_credentials_show', {channel: slug}) }}"
                                data-channel-card
                                data-search="{{ (channel.label ~ ' ' ~ channel.badge ~ ' ' ~ channel.description)|lower }}"
                            >
                                <span class="credential-avatar">{{ channel.label|slice(0, 1) }}</span>
                                <span class="credential-card-copy">
                                    <strong>{{ channel.label }}</strong>
                                    <small>{{ channel.configured_count }}/{{ channel.total_count }} gesetzt · {{ channel.file }}</small>
                                </span>
                                <span class="status-dot {{ channel.ready ? 'status-dot-ready' : 'status-dot-open' }}" title="{{ channel.ready ? 'Bereit' : 'Offen' }}"></span>
                            </a>
                        {% endif %}
                    {% endfor %}

                    {% if channels|length > 6 %}
                        <details class="nested-action-menu">
                            <summary>Weitere Systeme</summary>
                            <div class="credential-list">
                                {% for slug, channel in channels %}
                                    {% if loop.index > 6 %}
                                        <a
                                            class="credential-card {{ slug == active_slug ? 'active-card' : '' }}"
                                            href="{{ path('app_credentials_show', {channel: slug}) }}"
                                            data-channel-card
                                            data-search="{{ (channel.label ~ ' ' ~ channel.badge ~ ' ' ~ channel.description)|lower }}"
                                        >
                                            <span class="credential-avatar">{{ channel.label|slice(0, 1) }}</span>
                                            <span class="credential-card-copy">
                                                <strong>{{ channel.label }}</strong>
                                                <small>{{ channel.configured_count }}/{{ channel.total_count }} gesetzt · {{ channel.file }}</small>
                                            </span>
                                            <span class="status-dot {{ channel.ready ? 'status-dot-ready' : 'status-dot-open' }}" title="{{ channel.ready ? 'Bereit' : 'Offen' }}"></span>
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </details>
                    {% endif %}
                </div>
            </aside>

            <form class="credential-editor panel" method="post" autocomplete="off" data-credential-form>
                <input type="hidden" name="_token" value="{{ csrf_token('credentials_' ~ active_slug) }}">

                <header class="credential-editor-head">
                    <div>
                        <p class="eyebrow">{{ active_channel.badge }}</p>
                        <div class="row-between">
                            <h2>{{ active_channel.label }}</h2>
                            <span class="badge {{ active_channel.ready ? 'badge-success' : 'badge-warning' }}">
                                {{ active_channel.ready ? 'vollständig' : active_channel.required_missing_count ~ ' Pflichtfeld(er) offen' }}
                            </span>
                        </div>
                        <p>{{ active_channel.description }}</p>
                    </div>

                    <div class="credential-progress-card">
                        <span>{{ active_channel.configured_count }}/{{ active_channel.total_count }}</span>
                        <small>Felder gesetzt</small>
                        <div class="credential-progress" aria-label="Konfigurationsfortschritt">
                            <span style="width: {{ completion }}%"></span>
                        </div>
                    </div>
                </header>

                <details class="credential-detail-note">
                    <summary>Technische Details anzeigen</summary>
                    <p>Private Datei: <code>{{ active_channel.file_path }}</code></p>
                    <p>{{ active_channel.safety }}</p>
                </details>

                {% if not active_channel.is_writable %}
                    <div class="flash flash-warning">
                        Die private Konfigurationsablage ist aktuell nicht beschreibbar. Bitte Serverrechte für den Ordner prüfen.
                    </div>
                {% endif %}

                {% if active_channel.required_missing is not empty %}
                    <div class="credential-alert">
                        <strong>Noch offen</strong>
                        <span>{{ active_channel.required_missing|join(', ') }}</span>
                    </div>
                {% endif %}

                <div class="credential-field-grid">
                    {% for field in active_channel.fields %}
                        <div class="credential-field {{ field.type == 'checkbox' ? 'credential-field-toggle' : '' }}">
                            {% if field.type == 'checkbox' %}
                                <label class="toggle-row">
                                    <input name="credentials[{{ field.env }}]" type="checkbox" value="1" {% if field.checked %}checked{% endif %}>
                                    <span class="toggle-switch"></span>
                                    <span>
                                        <strong>{{ field.label }}</strong>
                                        <small>{{ field.env }}</small>
                                    </span>
                                </label>
                            {% else %}
                                <div class="credential-label-row">
                                    <label for="{{ field.env }}">
                                        {{ field.label }}
                                        {% if field.required|default(false) %}<span class="required-marker">*</span>{% endif %}
                                    </label>
                                </div>

                                {% if field.type == 'select' %}
                                    <select id="{{ field.env }}" name="credentials[{{ field.env }}]">
                                        {% for option in field.options|default([]) %}
                                            <option value="{{ option }}" {% if field.value == option %}selected{% endif %}>{{ option }}</option>
                                        {% endfor %}
                                    </select>
                                {% else %}
                                    {% set placeholder = field.placeholder|default('') %}
                                    {% if placeholder == '' and field.sensitive|default(false) and field.has_value %}
                                        {% set placeholder = field.masked_value %}
                                    {% endif %}

                                    <div class="{{ field.sensitive|default(false) ? 'secret-input-row' : '' }}">
                                        <input
                                            id="{{ field.env }}"
                                            name="credentials[{{ field.env }}]"
                                            type="{{ field.sensitive|default(false) ? 'password' : field.type }}"
                                            value="{{ field.value }}"
                                            placeholder="{{ placeholder }}"
                                            {% if field.sensitive|default(false) %}autocomplete="new-password" data-secret-input{% endif %}
                                        >
                                        {% if field.sensitive|default(false) %}
                                            <button class="icon-button" type="button" data-secret-toggle>anzeigen</button>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                <div class="field-meta">
                                    <code>{{ field.env }}</code>
                                    {% if field.sensitive|default(false) and field.has_value %}
                                        · gespeichert als {{ field.masked_value }}
                                    {% elseif field.required|default(false) and not field.has_value %}
                                        · fehlt noch
                                    {% elseif field.default|default('') %}
                                        · Standard: {{ field.default }}
                                    {% endif %}
                                    {% if field.help|default('') %}
                                        · {{ field.help }}
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                <div class="credential-save-bar">
                    <span data-save-state>Keine ungespeicherten Änderungen</span>
                    <div class="button-group">
                        <a class="button" href="{{ path('app_credentials_show', {channel: active_slug}) }}">Zurücksetzen</a>
                        <button class="button button-primary" type="submit">Speichern</button>
                    </div>
                </div>
            </form>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const initCredentialUx = () => {
                const page = document.querySelector('[data-credential-page]');
                if (!page || page.dataset.credentialUxReady === '1') {
                    return;
                }
                page.dataset.credentialUxReady = '1';

                const search = page.querySelector('[data-credential-search]');
                const cards = [...page.querySelectorAll('[data-channel-card]')];
                search?.addEventListener('input', () => {
                    const query = search.value.trim().toLowerCase();
                    cards.forEach((card) => {
                        card.hidden = query !== '' && !card.dataset.search.includes(query);
                    });
                });

                page.querySelectorAll('[data-secret-toggle]').forEach((button) => {
                    button.addEventListener('click', () => {
                        const input = button.closest('.secret-input-row')?.querySelector('[data-secret-input]');
                        if (!input) {
                            return;
                        }

                        const visible = input.type === 'text';
                        input.type = visible ? 'password' : 'text';
                        button.textContent = visible ? 'anzeigen' : 'verbergen';
                    });
                });

                const form = page.querySelector('[data-credential-form]');
                const saveState = page.querySelector('[data-save-state]');
                form?.addEventListener('input', () => {
                    page.classList.add('is-dirty');
                    if (saveState) {
                        saveState.textContent = 'Ungespeicherte Änderungen';
                    }
                }, { once: true });
            };

            document.addEventListener('DOMContentLoaded', initCredentialUx);
            document.addEventListener('turbo:load', initCredentialUx);
            initCredentialUx();
        })();
    </script>
{% endblock %}
